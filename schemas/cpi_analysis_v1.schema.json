{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "language": {
      "type": "string",
      "enum": ["ko"]
    },
    "executive_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "one_line": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["one_line", "detail"]
    },
    "inflation_interpretation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "core": {
          "type": "string",
          "minLength": 1
        },
        "momentum": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["headline", "core", "momentum"]
    },
    "policy_implication": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal": {
          "type": "string",
          "enum": ["hawkish", "dovish", "mixed", "neutral", "indeterminate"]
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "evidence_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["signal", "explanation", "evidence_paths"]
    },
    "key_points": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "evidence_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["title", "detail", "evidence_paths"]
      }
    },
    "risks_and_caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unsupported_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "section": {
            "type": "string",
            "enum": [
              "market_reaction",
              "asset_prices",
              "yield_curve",
              "positioning",
              "liquidity",
              "component_breakdown",
              "historical_analogs",
              "forecast_probabilities"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["section", "reason"]
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  },
  "required": [
    "language",
    "executive_summary",
    "inflation_interpretation",
    "policy_implication",
    "key_points",
    "risks_and_caveats",
    "unsupported_sections",
    "confidence"
  ]
}
